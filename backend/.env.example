# BROKI: Brain Rot Killer — local media review POC
# Copy this file to .env and fill in values as needed.

# Storage paths
BROKI_DB_PATH=/tmp/brainrot-guard/state.sqlite3
BROKI_MEDIA_DIR=/tmp/brainrot-media
BROKI_ARTIFACTS_DIR=/tmp/brainrot-guard/artifacts

# Opt-in live validation (0 = disabled for CI, 1 = enabled)
BROKI_LIVE_VALIDATE=0

# TRIBE v2 assets (required only when BROKI_LIVE_VALIDATE=1)
BROKI_TRIBE_CKPT=/path/to/tribe/checkpoint.pt
BROKI_FSAVERAGE5_DIR=/path/to/fsaverage5

# VLM provider (minicpm|gemini|xai)
BROKI_VLM_PROVIDER=minicpm

# Provider credentials (fill only the one you use)
BROKI_GEMINI_API_KEY=
BROKI_XAI_API_KEY=
BROKI_MINICPM_BASE_URL=
BROKI_MINICPM_API_KEY=

# Background worker (optional)
BROKI_ENABLE_WORKER=0
